---
import { codexBooks } from '@/config/codex';
---
<nav class="codex-contents" aria-labelledby="codex-contents-title">
  <p class="eyebrow">Codex I</p>
  <h2 id="codex-contents-title">Contents</h2>
  <ol>
    {codexBooks.map((book, index) => (
      <li>
        <a href={`#book-${index + 1}`}>
          <span>Book {book.number}</span>
          <strong>{book.title}</strong>
        </a>
      </li>
    ))}
  </ol>
</nav>

<style>
  .codex-contents {
    border-block: 1px solid var(--color-line);
    margin-block: var(--space-5);
    padding-block: var(--space-4);
  }

  h2 {
    font-family: var(--font-display);
    font-size: 2.3rem;
    font-weight: 500;
    margin: var(--space-2) 0 var(--space-3);
  }

  ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    border-top: 1px solid var(--color-line);
  }

  a {
    display: grid;
    gap: var(--space-1);
    padding-block: var(--space-3);
    text-decoration: none;
  }

  a:hover strong,
  a:focus-visible strong {
    text-decoration: underline;
  }

  span {
    color: var(--color-roman-red);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  strong {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
  }
</style>
