---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath: string;
}
const { currentPage, totalPages, basePath } = Astro.props;
const hrefFor = (page: number) => page <= 1 ? basePath : `${basePath}page/${page}/`;
---
{totalPages > 1 && (
  <nav class="pagination" aria-label="Pagination">
    <a href={hrefFor(currentPage - 1)} aria-disabled={currentPage === 1 ? 'true' : undefined} tabindex={currentPage === 1 ? -1 : undefined}>Previous</a>
    <ol>
      {Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
        <li><a href={hrefFor(page)} aria-current={page === currentPage ? 'page' : undefined}>{page}</a></li>
      ))}
    </ol>
    <a href={hrefFor(currentPage + 1)} aria-disabled={currentPage === totalPages ? 'true' : undefined} tabindex={currentPage === totalPages ? -1 : undefined}>Next</a>
  </nav>
)}
<style>
.pagination{align-items:center;border-top:1px solid var(--color-line);display:flex;font-family:var(--font-sans);gap:var(--space-3);justify-content:space-between;margin-top:var(--space-5);padding-top:var(--space-4)}
ol{display:flex;gap:var(--space-2);list-style:none;margin:0;padding:0}a{text-decoration:none}a:hover,a:focus-visible,a[aria-current='page']{text-decoration:underline}a[aria-disabled='true']{color:var(--color-muted);pointer-events:none}
</style>
