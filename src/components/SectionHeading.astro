---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  id?: string;
}

const { eyebrow, title, description, id } = Astro.props;
---
<header class="section-heading">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 id={id}>{title}</h2>
  {description && <p class="description">{description}</p>}
</header>

<style>
  .section-heading {
    margin-bottom: var(--space-4);
    max-width: 52rem;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 1.6rem + 2.6vw, 4.4rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 0.98;
    margin: var(--space-2) 0;
  }

  .description {
    color: var(--color-muted);
    font-size: 1.15rem;
    line-height: 1.55;
    max-width: 44rem;
  }
</style>
