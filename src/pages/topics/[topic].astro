---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ObservationCard from '@/components/ObservationCard.astro';
import { getTopics } from '@/lib/topics';

export async function getStaticPaths() {
  const topics = await getTopics();

  return topics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
---
<BaseLayout
  title={topic.label}
  description={`Romanisti observations filed under ${topic.label}.`}
>
  <header class="container topic-header">
    <p class="eyebrow">Topic</p>
    <h1>{topic.label}</h1>
    <p>{topic.count} observation{topic.count === 1 ? '' : 's'} in the record.</p>
  </header>

  <section class="container topic-results" aria-label={`${topic.label} observations`}>
    {topic.entries.map((entry) => <ObservationCard entry={entry} />)}
  </section>
</BaseLayout>

<style>
  .topic-header {
    padding-block: var(--space-6);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 5vw, 7rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    margin: var(--space-2) 0 var(--space-3);
  }

  .topic-header > p:last-child {
    color: var(--color-muted);
    font-family: var(--font-sans);
  }

  .topic-results {
    padding-bottom: var(--space-6);
  }
</style>
