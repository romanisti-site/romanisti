---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getObservationArchive } from '@/lib/archive';
import { formatEditorialDate } from '@/lib/date';
const groups = await getObservationArchive();
---
<BaseLayout title="Observation Archive" description="The complete chronological record of published Romanisti observations.">
<header class="container archive-header"><p class="eyebrow">The Record</p><h1>Archive</h1><p>Every published observation, preserved in chronological order.</p></header>
<div class="container archive">{groups.map((group)=>(<section aria-labelledby={`year-${group.year}`}><h2 id={`year-${group.year}`}>{group.year}</h2><ol>{group.entries.map((entry)=>(<li><time datetime={entry.data.publishedAt.toISOString()}>{formatEditorialDate(entry.data.publishedAt)}</time><a href={`/observations/${entry.id}/`}>{entry.data.title}</a></li>))}</ol></section>))}</div>
</BaseLayout>
<style>
.archive-header{padding-block:var(--space-6)}h1{font-family:var(--font-display);font-size:clamp(3rem,2rem + 5vw,7rem);font-weight:500;letter-spacing:-.045em;margin:var(--space-2) 0 var(--space-4)}.archive-header>p:last-child{color:var(--color-muted);font-size:1.2rem;max-width:44rem}.archive{padding-bottom:var(--space-6)}section{border-top:1px solid var(--color-line);padding-block:var(--space-5)}h2{font-family:var(--font-display);font-size:2.6rem;font-weight:500}ol{list-style:none;margin:0;padding:0}li{display:grid;gap:var(--space-3);grid-template-columns:minmax(9rem,12rem) 1fr;padding-block:var(--space-2)}time{color:var(--color-muted);font-family:var(--font-sans);font-size:.75rem}a{text-decoration:none}a:hover,a:focus-visible{text-decoration:underline}@media(max-width:38rem){li{grid-template-columns:1fr;gap:var(--space-1)}}
</style>
