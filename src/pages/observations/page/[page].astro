---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ObservationCard from '@/components/ObservationCard.astro';
import Pagination from '@/components/Pagination.astro';
import { pagination } from '@/config/pagination';
import { getPublishedObservations } from '@/lib/content';
export async function getStaticPaths(){const observations=await getPublishedObservations();const totalPages=Math.max(1,Math.ceil(observations.length/pagination.observationsPerPage));return Array.from({length:Math.max(0,totalPages-1)},(_,index)=>{const currentPage=index+2;const start=(currentPage-1)*pagination.observationsPerPage;return{params:{page:String(currentPage)},props:{currentPage,totalPages,entries:observations.slice(start,start+pagination.observationsPerPage)}}})}
const {currentPage,totalPages,entries}=Astro.props;
---
<BaseLayout title={`Observations — Page ${currentPage}`} description={`Published Romanisti observations, page ${currentPage}.`}><header class="container page-header"><p class="eyebrow">Editorial</p><h1>Observations</h1><p>Page {currentPage} of {totalPages}</p></header><section class="container list" aria-label={`Published observations, page ${currentPage}`}>{entries.map((entry)=><ObservationCard entry={entry}/>)}<Pagination currentPage={currentPage} totalPages={totalPages} basePath="/observations/"/></section></BaseLayout>
<style>.page-header{padding-block:var(--space-6)}h1{font-family:var(--font-display);font-size:clamp(3rem,2rem + 5vw,7rem);font-weight:500;letter-spacing:-.04em;margin:var(--space-2) 0}.page-header>p:last-child{color:var(--color-muted);font-family:var(--font-sans)}.list{padding-bottom:var(--space-6)}</style>
