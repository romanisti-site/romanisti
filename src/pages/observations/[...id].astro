---
import { getCollection, render } from 'astro:content';
import EditorialLayout from '@/layouts/EditorialLayout.astro';
import RelatedObservations from '@/components/RelatedObservations.astro';
import { getRelatedObservations } from '@/lib/related';

export async function getStaticPaths() {
  const entries = await getCollection(
    'observations',
    ({ data }) => data.status === 'published',
  );

  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const related = await getRelatedObservations(entry);
---
<EditorialLayout
  title={entry.data.title}
  description={entry.data.description}
  publishedAt={entry.data.publishedAt}
  author={entry.data.author}
  updatedAt={entry.data.updatedAt}
>
  <Content />
  <RelatedObservations entries={related} />
</EditorialLayout>
