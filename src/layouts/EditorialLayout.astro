---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatEditorialDate } from '@/lib/date';

interface Props {
  title: string;
  description: string;
  publishedAt?: Date;
  author?: string;
}

const { title, description, publishedAt, author } = Astro.props;
---
<BaseLayout title={title} description={description} type="article">
  <article class="container article-shell">
    <header>
      <p class="eyebrow">Romanisti · Observation</p>
      <h1>{title}</h1>
      <p class="standfirst">{description}</p>
      {(publishedAt || author) && (
        <p class="byline">
          {author && <span>By {author}</span>}
          {publishedAt && <time datetime={publishedAt.toISOString()}>{formatEditorialDate(publishedAt)}</time>}
        </p>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    padding-block: var(--space-6);
  }

  header {
    border-bottom: 1px solid var(--color-line);
    margin-bottom: var(--space-5);
    max-width: 58rem;
    padding-bottom: var(--space-5);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 2rem + 4vw, 6.5rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 0.96;
    margin: var(--space-2) 0 var(--space-3);
  }

  .standfirst {
    color: var(--color-muted);
    font-size: clamp(1.15rem, 1rem + 0.6vw, 1.55rem);
    line-height: 1.5;
    max-width: 46rem;
  }

  .byline {
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
</style>
